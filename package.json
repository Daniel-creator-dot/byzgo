{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run flutter:android",
    "dev:web": "vite",
    "dev:admin": "vite --open /admin",
    "admin": "powershell -ExecutionPolicy Bypass -File scripts/run-admin-local.ps1",
    "admin:web": "npm run dev:admin",
    "backend": "npm --prefix backend run dev",
    "create:admin": "node backend/scripts/create-admin.mjs",
    "create:vendor": "node backend/scripts/create-vendor.mjs",
    "seed:primecare": "node backend/scripts/seed-primecare-pharmacy.mjs",
    "seed:accra-places": "node backend/scripts/seed-accra-popular-places.mjs",
    "seed:accra-groceries": "node backend/scripts/seed-accra-popular-places.mjs --groceries",
    "seed:accra-shops": "node backend/scripts/seed-accra-popular-places.mjs && node backend/scripts/seed-accra-popular-places.mjs --groceries",
    "dedupe:primecare": "node backend/scripts/dedupe-primecare-vendor.mjs",
    "parse:formulary": "python scripts/parse_drug_formulary.py",
    "app": "npm run flutter:android",
    "icons": "python mobile/scripts/generate_app_icon.py",
    "mobile:sync-maps": "node mobile/scripts/sync_maps_key.mjs",
    "flutter:chrome": "cd mobile && ..\\.flutter-sdk\\bin\\flutter run -d chrome --dart-define-from-file=dart_defines.json",
    "setup:android-studio": "powershell -ExecutionPolicy Bypass -File mobile/scripts/setup_android_studio.ps1",
    "flutter:android": "cd mobile && ..\\.flutter-sdk\\bin\\flutter run -d emulator-5554 --dart-define-from-file=dart_defines.json --dart-define=API_URL=https://www.bytzgo.net",
    "flutter:android:local": "cd mobile && ..\\.flutter-sdk\\bin\\flutter run -d emulator-5554 --dart-define-from-file=dart_defines.json --dart-define=API_URL=http://10.0.2.2:3000",
    "flutter:android:live": "npm run flutter:android",
    "flutter:build:apk": "powershell -ExecutionPolicy Bypass -File mobile/scripts/build_apk.ps1",
    "release:android": "npm run flutter:build:apk && node scripts/copy-apk-to-public.mjs",
    "flutter:build:aab": "powershell -ExecutionPolicy Bypass -File mobile/scripts/build_aab.ps1",
    "flutter:validate:ios": "bash mobile/scripts/validate_app_store.sh",
    "flutter:build:ipa": "bash mobile/scripts/build_ios_ipa.sh",
    "flutter:build:ios": "bash mobile/scripts/build_ios.sh",
    "sync:ios-version": "bash scripts/sync-ios-version.sh",
    "release:ios": "bash scripts/sync-ios-version.sh && bash mobile/scripts/build_app_store_ipa.sh",
    "play:setup": "powershell -ExecutionPolicy Bypass -File mobile/scripts/setup_play_store.ps1",
    "play:validate": "powershell -ExecutionPolicy Bypass -File mobile/scripts/validate_play_release.ps1",
    "setup:firebase:android": "npm --prefix backend run setup:firebase:android",
    "copy:legal": "node scripts/copy-legal-to-public.mjs",
    "build:render": "npm ci && npm run copy:legal && npm run build && node scripts/sync-apk-for-render.mjs && npm install --prefix backend --omit=dev",
    "redeploy:production:sh": "bash scripts/redeploy-production.sh",
    "start:render": "npm --prefix backend run start",
    "start": "vite",
    "build": "npm run copy:legal && vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "check:sms": "node backend/scripts/test-sms.mjs",
    "setup:storage": "powershell -ExecutionPolicy Bypass -File scripts/apply-supabase-key.ps1",
    "check:paystack": "node backend/scripts/check-paystack.mjs",
    "check:render-api": "powershell -ExecutionPolicy Bypass -File scripts/verify-render-api.ps1",
    "redeploy:production": "powershell -ExecutionPolicy Bypass -File scripts/redeploy-production.ps1",
    "setup:render": "powershell -ExecutionPolicy Bypass -File scripts/setup-render.ps1",
    "prepare:render-env": "powershell -ExecutionPolicy Bypass -File scripts/prepare-render-env.ps1"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-oauth/google": "^0.12.2",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
