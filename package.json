{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run flutter:android",
    "backend": "npm --prefix backend run dev",
    "app": "npm run flutter:android",
    "icons": "python mobile/scripts/generate_app_icon.py",
    "flutter:chrome": "cd mobile && ..\\.flutter-sdk\\bin\\flutter run -d chrome --dart-define-from-file=dart_defines.json",
    "flutter:android": "cd mobile && ..\\.flutter-sdk\\bin\\flutter run -d emulator-5554 --dart-define-from-file=dart_defines.json --dart-define=API_URL=http://10.0.2.2:3000",
    "flutter:build:apk": "powershell -ExecutionPolicy Bypass -File mobile/scripts/build_apk.ps1",
    "build:render": "npm install --prefix backend --omit=dev",
    "start:render": "npm --prefix backend run start",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "check:sms": "node backend/scripts/test-sms.mjs",
    "check:paystack": "node backend/scripts/check-paystack.mjs",
    "check:render-api": "powershell -ExecutionPolicy Bypass -File scripts/verify-render-api.ps1",
    "setup:render": "powershell -ExecutionPolicy Bypass -File scripts/setup-render.ps1",
    "prepare:render-env": "powershell -ExecutionPolicy Bypass -File scripts/prepare-render-env.ps1"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-oauth/google": "^0.13.5",
    "@supabase/supabase-js": "^2.106.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vis.gl/react-google-maps": "^1.8.3",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.15.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
