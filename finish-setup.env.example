# Copy to .env.local (gitignored) and fill in values, then run:
#   ./scripts/finish-all.sh
#
# Apple — app-specific password (NOT your Apple ID password):
#   https://account.apple.com → Sign-In and Security → App-Specific Passwords
APPLE_ID=jerryanthony61@gmail.com
APPLE_APP_SPECIFIC_PASSWORD=

# Cloudflare — API token with Zone.DNS Edit for bytzgo.net:
#   https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Render — new API key after revoking the old one:
#   https://dashboard.render.com/u/settings#api-keys
RENDER_API_KEY=
