# Frontend (Vite) — copy to .env.local
GEMINI_API_KEY=MY_GEMINI_API_KEY
# Google Maps — create key at https://console.cloud.google.com/google/maps-apis
# Required: enable BILLING + Maps JavaScript API, Places API, Geocoding API, Directions API
# For local dev, allow HTTP referrer: http://localhost:5173/*
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# Google Sign-In (Firebase web OAuth client — from Firebase Console → Authentication → Google)
GOOGLE_WEB_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend — copy to backend/.env
DATABASE_URL=postgresql://user:password@host:5432/postgres
JWT_SECRET=change-me-in-production
# Set on Render/Supabase if Postgres requires SSL (auto-enabled for production + known hosts)
PG_SSL=true
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
FIREBASE_PROJECT_ID=bytzgo-72f1c
PORT=3000

# Paystack (backend verifies wallet top-ups — must pair test with test, live with live)
PAYSTACK_PUBLIC_KEY=pk_test_your_key_here
PAYSTACK_SECRET_KEY=sk_test_your_key_here

# Default delivery rate (₵ per km) — also editable in Admin → Settings
# DELIVERY_PRICE_PER_KM=4

# Admin self-registration secret (required to create admin accounts via /admin signup)
ADMIN_INVITE_SECRET=change-me-admin-invite

# Production: set to your API origin (same host for REST + Socket.IO). Leave empty in dev to use Vite proxy.
VITE_API_URL=

# Flutter APK / physical device — public API URL (https recommended). Used by mobile/scripts/build_apk.ps1
# Production (after Render deploy): https://bytzgo-api.onrender.com  or  https://api.bytzgo.net
# Local Wi-Fi test: http://192.168.1.10:3000
MOBILE_API_URL=https://bytzgo.net

# Web Push (optional — auto-generated and stored in DB if omitted)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@bytzgo.com

# INTEK SMS (OTP for signup / forgot password — env overrides DB; also Admin → Settings)
SMS_BASE_URL=https://www.inteksms.top/api/v1
SMS_API_KEY=your-intek-api-key
SMS_SENDER_ID=bytzee
# Local only: print OTP codes in backend console when SMS is sent
SMS_LOG_OTP=true
