# Copy to android/local.properties (or run mobile/scripts/setup_android_studio.ps1 on Windows).
#
# Windows example:
# flutter.sdk=C:\\src\\flutter
# sdk.dir=C:\\Users\\YOUR_USER\\AppData\\Local\\Android\\Sdk
# GOOGLE_MAPS_API_KEY=your-android-maps-sdk-key
#
# macOS example:
# flutter.sdk=/Users/you/flutter
# sdk.dir=/Users/you/Library/Android/sdk
